mainmenu "Matter nRF Connect Temperature Sensor Example Application"

choice OPENTHREAD_NORDIC_LIBRARY_CONFIGURATION
	default OPENTHREAD_NORDIC_LIBRARY_MTD
endchoice

choice OPENTHREAD_DEVICE_TYPE
	default OPENTHREAD_MTD
endchoice

config CHIP_ENABLE_ICD_SUPPORT
	default y

config CHIP_ICD_LIT_SUPPORT
	default y

config CHIP_ICD_SIT_SLOW_POLL_LIMIT
	default 5000

config CHIP_ICD_REPORT_ON_ACTIVE_MODE
	default y

# Application logging verbosity gate
config TINYENV_VERBOSE_LOGS
	bool "Enable verbose TinyENV nRF sensor logs"
	default n

config TINYENV_DISABLE_BOARD_UI
	bool "Disable board UI (LED widget/event handler)"
	default n

config TINYENV_ENABLE_STATUS_LED_ACTIVITY
	bool "Enable status LED thread and sensor-pulse LED"
	default y

config TINYENV_ENABLE_BOOT_I2C_SCAN
	bool "Enable I2C bus scan at boot"
	default y

config TINYENV_POST_COMMISSION_THREAD_TX_POWER_DBM
	int "Thread TX power after commissioning (dBm)"
	range -20 20
	default 0
	help
	  Runtime Thread TX power used after commissioning hold expires.
	  During commissioning window and post-close grace, firmware forces
	  full power for reliability.

config TINYENV_DIAGNOSTIC_MODE
	bool "Enable diagnostic telemetry mode"
	default n
	help
	  Enables persistent counters, reset-cause tracking, watchdog setup,
	  periodic health snapshots, and detached-role recovery logging.

config TINYENV_DIAG_WATCHDOG_TIMEOUT_SEC
	int "Diagnostic watchdog timeout (seconds)"
	range 30 3600
	default 180
	depends on TINYENV_DIAGNOSTIC_MODE

config TINYENV_DIAG_SNAPSHOT_INTERVAL_SEC
	int "Diagnostic health snapshot interval (seconds)"
	range 60 3600
	default 600
	depends on TINYENV_DIAGNOSTIC_MODE

config TINYENV_DIAG_DETACHED_REBOOT_SEC
	int "Commissioned detached-role reboot threshold (seconds)"
	range 60 3600
	default 300
	depends on TINYENV_DIAGNOSTIC_MODE

# Keep Thread TX power high enough for robust parent/router handoffs.
config OPENTHREAD_DEFAULT_TX_POWER
	default 8

source "$(ZEPHYR_CONNECTEDHOMEIP_MODULE_DIR)/config/nrfconnect/chip-module/Kconfig.features"
source "$(ZEPHYR_CONNECTEDHOMEIP_MODULE_DIR)/config/nrfconnect/chip-module/Kconfig.defaults"
source "$(ZEPHYR_NRF_MODULE_DIR)/samples/matter/common/src/Kconfig"
source "Kconfig.zephyr"
